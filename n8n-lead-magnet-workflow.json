        [{ "node": "Send Lead Magnet Email", "type": "main", "index": 0 }]
      ]
    },
    "Send Lead Magnet Email": {
      "main": [
        [{ "node": "Respond OK", "type": "main", "index": 0 }]
      ]
    }
